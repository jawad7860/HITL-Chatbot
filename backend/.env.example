# Groq API key — get one for free at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: GitHub token for higher rate limits on the GitHub tool
# Public repo read works without one but you'll hit 60 req/hr unauthenticated.
GITHUB_TOKEN=

# LLM model (Groq-hosted). Llama 3.3 70B is the most reliable for tool-calling
# on the free tier. Check https://console.groq.com/docs/models for current list.
LLM_MODEL=llama-3.3-70b-versatile

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Checkpointer DB path (relative to backend/)
CHECKPOINT_DB=data/checkpoints.db
